<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.me.canteen.mapper.CanteenMapper">
    <select id="findAll" resultType="com.me.canteen.entity.Canteen">
        SELECT * FROM canteens WHERE is_active = 1
    </select>
    <select id="findById" resultType="com.me.canteen.entity.Canteen">
        SELECT * FROM canteens WHERE id = #{id}
    </select>
</mapper>
