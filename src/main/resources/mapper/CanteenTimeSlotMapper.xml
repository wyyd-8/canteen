<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.me.canteen.mapper.CanteenTimeSlotMapper">
    <select id="findById" resultType="com.me.canteen.entity.CanteenTimeSlot">
        SELECT * FROM canteen_time_slots WHERE id = #{id}
    </select>

    <select id="findCurrentSlot" resultType="com.me.canteen.entity.CanteenTimeSlot">
        SELECT * FROM canteen_time_slots 
        WHERE canteen_id = #{canteenId} 
        AND slot_date = #{date} 
        AND start_time &lt;= #{time} 
        AND end_time &gt;= #{time}
        LIMIT 1
    </select>
</mapper>
