<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.me.canteen.mapper.UserMapper">
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (user_no, user_name, phone, password, role)
        VALUES (#{userNo}, #{userName}, #{phone}, #{password}, #{role})
    </insert>
    <select id="findById" resultType="com.me.canteen.entity.User">
        SELECT * FROM users WHERE id = #{id}
    </select>
    <select id="findByUserNo" resultType="com.me.canteen.entity.User">
        SELECT * FROM users WHERE user_no = #{userNo}
    </select>
    <select id="findByPhone" resultType="com.me.canteen.entity.User">
        SELECT * FROM users WHERE phone = #{phone}
    </select>
</mapper>
